{
  "name": "lumo-backend",
  "version": "0.1.0",
  "description": "Lumo (lumo.app) — backend API, NestJS modular monolith (doc 18)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/config/typeorm.config.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:generate": "npm run typeorm -- migration:generate",
    "test": "jest test/unit",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/integration",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/websockets": "^10.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/config": "^3.2.3",
    "@nestjs/bull": "^10.2.0",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/graphql": "^12.2.0",
    "@nestjs/apollo": "^12.2.0",
    "@apollo/server": "^4.11.0",
    "graphql": "^16.9.0",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-yet": "^5.1.5",
    "swagger-ui-express": "^5.0.1",
    "stripe": "^16.9.0",
    "prom-client": "^15.1.3",
    "nanoid": "^3.3.7",
    "typeorm": "^0.3.20",
    "pg": "^8.12.0",
    "redis": "^4.7.0",
    "ioredis": "^5.4.1",
    "bull": "^4.16.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "argon2": "^0.40.3",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "socket.io": "^4.7.5",
    "@socket.io/redis-adapter": "^8.3.0",
    "@aws-sdk/client-s3": "^3.637.0",
    "@aws-sdk/s3-request-presigner": "^3.637.0",
    "uuid": "^10.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "@types/supertest": "^6.0.2",
    "@types/jest": "^29.5.12",
    "supertest": "^7.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": "test/.*\\.(spec|integration-spec)\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["src/**/*.(t|j)s"],
    "coverageDirectory": "./coverage"
  }
}
