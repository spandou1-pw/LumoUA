# Lumo backend — local environment template (doc 31: never commit real secrets)

NODE_ENV=development
PORT=3000
CORS_ORIGIN=

# Database (doc 20)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=lumo
DATABASE_PASSWORD=lumo_local_dev_only
DATABASE_NAME=lumo_dev

# Redis (cache, pub/sub backplane, BullMQ — doc 18)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (doc 23) — in production, use an RS256 key pair, not a shared HS256 secret.
# JWT_PRIVATE_KEY / JWT_PUBLIC_KEY (PEM, base64-encoded) take precedence if set.
JWT_ACCESS_SECRET=replace_me_dev_only
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Object storage — Cloudflare R2 (S3-compatible, doc 30)
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_BUCKET=lumo-media-dev
STORAGE_ACCESS_KEY_ID=replace_me
STORAGE_SECRET_ACCESS_KEY=replace_me
STORAGE_PUBLIC_BASE_URL=https://cdn.lumo.app

# Push notifications (doc 25) — Expo push service wraps APNs/FCM
EXPO_PUSH_ACCESS_TOKEN=replace_me

# Payments (Stage 6 — doc PAYMENTS.md)
APP_PUBLIC_URL=https://lumo.app
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Apple IAP (App Store Server API) — real production values required, see
# src/modules/payments/providers/apple-iap.provider.ts for what each is used for
APPLE_IAP_PRIVATE_KEY=replace_me
APPLE_IAP_KEY_ID=replace_me
APPLE_IAP_ISSUER_ID=replace_me
APPLE_IAP_BUNDLE_ID=app.lumo.ua
# Google Play Billing (Play Developer API) — service account JSON, see
# src/modules/payments/providers/google-play.provider.ts
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=replace_me
GOOGLE_PLAY_PACKAGE_NAME=app.lumo.ua

# AI Platform (Stage 14 — doc AI.md) — real credentials required for the
# classifier/translation providers; every one throws NOT_IMPLEMENTED
# clearly rather than returning fake results when unset.
TEXT_MODERATION_API_KEY=replace_me
VISUAL_MODERATION_API_KEY=replace_me
TRANSLATION_API_KEY=replace_me

# Bot Detection (Stage 15 — doc SECURITY.md)
TURNSTILE_SECRET_KEY=replace_me

# Campaigns (Stage 16 — doc GROWTH.md)
EMAIL_PROVIDER_API_KEY=replace_me


